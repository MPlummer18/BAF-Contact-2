PORT=3000

# Address lookup provider. Default is palegis, which submits the user's address
# server-side to https://www.palegis.us/find-my-legislator and parses the result.
# Alternative: geocodio
LOOKUP_PROVIDER=palegis
GEOCODIO_API_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Organization Name <no-reply@example.org>"
ORGANIZATION_CC_EMAIL=
